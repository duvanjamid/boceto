{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/lib",
    "declaration": true,
    "declarationDir": "dist/lib",
    "module": "ES2022",
    "moduleResolution": "node",
    "target": "ES2020",
    "sourceMap": false,
    "inlineSources": false,
    "stripInternal": true
  },
  "include": [
    "src/parser.ts",
    "src/types.ts",
    "src/themes.js"
  ],
  "exclude": [
    "src/app",
    "src/boceto-lang.ts",
    "node_modules"
  ],
  "angularCompilerOptions": {}
}
